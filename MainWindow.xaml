<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CreditSimulator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CreditSimulator"
    xmlns:converters="using:CreditSimulator.Converters"
    xmlns:models="using:CreditSimulator.Models"
    xmlns:num="using:Windows.Globalization.NumberFormatting"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    Title="Simulator Kredit">
    
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="rootGrid" Padding="60,40" ColumnSpacing="32" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="480" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,40">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Border Background="#E6F4EA" CornerRadius="12" Padding="12">
<Image Source="Assets/logo_toko.png" Width="40" Height="40" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Simulator Kredit" FontSize="32" FontWeight="Bold" Foreground="#202124" />
                    <TextBlock Text="Hitung simulasi cicilan &amp; pelunasan dipercepat" FontSize="16" Foreground="#5F6368" />
                </StackPanel>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="24">
                    <ToggleSwitch Header="Mulai Otomatis" IsOn="{Binding IsStartupEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                    <ToggleSwitch Header="Mode Pelanggan" IsOn="{Binding IsCustomerMode, Mode=TwoWay}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
            
            <InfoBar Grid.Row="0" Grid.ColumnSpan="2" IsOpen="{Binding IsErrorVisible, Mode=OneWay}" Severity="Error" Title="Error" Message="{Binding ErrorMessage}" Margin="0,0,0,20" VerticalAlignment="Bottom" />

            <!-- LEFT COLUMN: Inputs -->
        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="24" VerticalAlignment="Top">
            
            <!-- Input Simulasi Card -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE13D;" FontSize="18" Foreground="#0F9D58" />
                            <TextBlock Text="Input Simulasi" FontWeight="Bold" FontSize="18" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="HARGA BARANG" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368" />
                            <NumberBox x:Name="priceInput" Header="Harga Barang (Rp)" Value="{Binding ProductPrice, Mode=TwoWay}" LargeChange="1000000" SmallChange="100000" SpinButtonPlacementMode="Inline" FontSize="16" PlaceholderText="0" Language="id-ID" />
                            <TextBlock Text="{Binding FormattedProductPrice}" FontSize="14" Foreground="#80868B" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="UANG MUKA (DP)" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368" />
                            <NumberBox x:Name="dpInput" Header="Uang Muka / DP (Minimal 20%)" Value="{Binding DownPayment, Mode=TwoWay}" LargeChange="500000" SmallChange="50000" SpinButtonPlacementMode="Inline" FontSize="16" PlaceholderText="0" Language="id-ID" />
                            <TextBlock Text="{Binding FormattedDownPayment}" FontSize="14" Foreground="#80868B" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="TENOR" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="48" />
                                    <RowDefinition Height="48" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Button Grid.Row="0" Grid.Column="0" Command="{Binding SelectTenorCommand}" CommandParameter="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="8" Background="{Binding Tenor3Bg}">
                                    <TextBlock Text="3 Bulan" FontWeight="SemiBold" Foreground="{Binding Tenor3Fg}" />
                                </Button>
                                <Button Grid.Row="0" Grid.Column="1" Command="{Binding SelectTenorCommand}" CommandParameter="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="8" Background="{Binding Tenor6Bg}">
                                    <TextBlock Text="6 Bulan" FontWeight="SemiBold" Foreground="{Binding Tenor6Fg}" />
                                </Button>
                                <Button Grid.Row="1" Grid.Column="0" Command="{Binding SelectTenorCommand}" CommandParameter="9" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="8" Background="{Binding Tenor9Bg}">
                                    <TextBlock Text="9 Bulan" FontWeight="SemiBold" Foreground="{Binding Tenor9Fg}" />
                                </Button>
                                <Button Grid.Row="1" Grid.Column="1" Command="{Binding SelectTenorCommand}" CommandParameter="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="8" Background="{Binding Tenor12Bg}">
                                    <TextBlock Text="12 Bulan" FontWeight="SemiBold" Foreground="{Binding Tenor12Fg}" />
                                </Button>
                            </Grid>
                        </StackPanel>
                        
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="16" Margin="0,10,0,0" Visibility="{Binding AdminVisibility}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Harga Pokok" Foreground="#5F6368" />
                                    <TextBlock Text="{Binding FormattedPrincipal}" FontWeight="Bold" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Biaya Admin" Foreground="#5F6368" />
                                    <TextBlock Text="{Binding FormattedAdminFee}" FontWeight="Bold" Foreground="#0F9D58" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Faktor Pengali" Foreground="#5F6368" />
                                    <TextBlock Text="{Binding FormattedActiveFactor}" FontWeight="Bold" Foreground="#1A73E8" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Pelunasan Dipercepat Expander -->
                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Margin="0,0,0,0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="0,12">
                            <FontIcon Glyph="&#xE8B0;" FontSize="18" Foreground="#0F9D58" />
                            <TextBlock Text="Pelunasan Dipercepat" FontWeight="Bold" FontSize="18" />
                        </StackPanel>
                    </Expander.Header>
                    
                    <StackPanel Spacing="20" Padding="0,8,0,16">
                        <Border Background="#E6F4EA" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="#0F9D58" VerticalAlignment="Top" Margin="0,2,0,0" />
                                <TextBlock Text="Jika pelanggan ingin melunasi sebelum tenor habis, hitung sisa kewajiban." 
                                           Foreground="#0D652D" FontSize="12" TextWrapping="Wrap" MaxWidth="300" />
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Bulan Sudah Dibayar" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368" />
                            <NumberBox Header="Cicilan Berjalan (Bulan ke-)" Value="{Binding MonthsAlreadyPaid, Mode=TwoWay}" Minimum="1" Maximum="11" SpinButtonPlacementMode="Inline" FontSize="16" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Tenor Target" FontSize="14" FontWeight="SemiBold" Foreground="#5F6368" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Command="{Binding SelectTargetTenorCommand}" CommandParameter="3" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" Background="{Binding Target3Bg}">
                                    <TextBlock Text="3 bln" FontWeight="SemiBold" Foreground="{Binding Target3Fg}" />
                                </Button>
                                <Button Grid.Column="1" Command="{Binding SelectTargetTenorCommand}" CommandParameter="6" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" Background="{Binding Target6Bg}">
                                    <TextBlock Text="6 bln" FontWeight="SemiBold" Foreground="{Binding Target6Fg}" />
                                </Button>
                                <Button Grid.Column="2" Command="{Binding SelectTargetTenorCommand}" CommandParameter="9" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" Background="{Binding Target9Bg}">
                                    <TextBlock Text="9 bln" FontWeight="SemiBold" Foreground="{Binding Target9Fg}" />
                                </Button>
                            </Grid>
                        </StackPanel>
                        
                        <Border Background="#E6F4EA" CornerRadius="8" Padding="16" Margin="0,10,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="SISA KEWAJIBAN PELUNASAN" FontSize="13" FontWeight="Bold" Foreground="#0F9D58" />
                                <TextBlock Text="{Binding FormattedEarlyPayoffAmount}" FontSize="32" FontWeight="Bold" Foreground="#0F9D58" />
                                <TextBlock Text="{Binding EarlyPayoffFormulaText}" FontSize="12" Foreground="#0D652D" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander>
        </StackPanel>
        
        <!-- RIGHT COLUMN: Outputs -->
        <Grid Grid.Row="1" Grid.Column="1" RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Top 3 Cards -->
            <Grid Grid.Row="0" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="CICILAN / BULAN" FontSize="14" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FormattedMonthlyInstallment}" FontSize="42" FontWeight="Bold" Foreground="#0F9D58" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedTenorSubtitle}" FontSize="14" Foreground="#80868B" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="PEMBAYARAN PERTAMA" FontSize="14" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FormattedFirstPayment}" FontSize="42" FontWeight="Bold" Foreground="#F9AB00" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FirstPaymentSubtitle}" FontSize="14" Foreground="#80868B" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Padding="24" Visibility="{Binding AdminVisibility}">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="MARGIN KEUNTUNGAN" FontSize="14" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FormattedTotalMargin}" FontSize="42" FontWeight="Bold" Foreground="#0F9D58" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FormattedMarginPercentage}" FontSize="14" Foreground="#80868B" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
            </Grid>

            <!-- Comparison Table Card -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Padding="24" VerticalAlignment="Stretch">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE904;" FontSize="18" Foreground="#0F9D58" />
                            <TextBlock Text="Perbandingan Semua Tenor" FontWeight="Bold" FontSize="18" />
                        </StackPanel>
                        
                        <Grid ColumnSpacing="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{Binding FactorColumnWidth}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{Binding MarginColumnWidth}" />
                                <ColumnDefinition Width="{Binding PercentColumnWidth}" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TENOR" FontSize="{Binding TableHeaderFontSize}" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Left" />
                            <TextBlock Grid.Column="1" Text="FAKTOR" FontSize="{Binding TableHeaderFontSize}" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Center" Visibility="{Binding AdminVisibility}"/>
                            <TextBlock Grid.Column="2" Text="CICILAN/BULAN" FontSize="{Binding TableHeaderFontSize}" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="TOTAL KEWAJIBAN" FontSize="{Binding TableHeaderFontSize}" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="MARGIN" FontSize="{Binding TableHeaderFontSize}" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Right" Visibility="{Binding AdminVisibility}"/>
                            <TextBlock Grid.Column="5" Text="%" FontSize="{Binding TableHeaderFontSize}" FontWeight="Bold" Foreground="#80868B" HorizontalAlignment="Right" Visibility="{Binding AdminVisibility}"/>
                        </Grid>
                        
                        <Border Height="1" Background="#E0E0E0" />

                        <ItemsControl ItemsSource="{Binding Comparisons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TenorComparisonRecord">
                                    <Grid Margin="0,12" ColumnSpacing="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="{Binding FactorColumnWidth}" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="{Binding MarginColumnWidth}" />
                                            <ColumnDefinition Width="{Binding PercentColumnWidth}" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" CornerRadius="16" Background="{Binding BadgeBackground}" Padding="12,6" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Title}" FontSize="{Binding DataContext.TableContentFontSize, ElementName=rootGrid}" FontWeight="SemiBold" Foreground="{Binding BadgeForeground}" />
                                        </Border>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding FormattedFactor}" FontSize="{Binding DataContext.TableContentFontSize, ElementName=rootGrid}" FontWeight="SemiBold" Foreground="#1A73E8" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding MarginVisibility}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding FormattedMonthlyInstallment}" FontSize="{Binding DataContext.TableContentFontSize, ElementName=rootGrid}" FontWeight="Bold" Foreground="#202124" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding FormattedTotalCredit}" FontSize="{Binding DataContext.TableContentFontSize, ElementName=rootGrid}" FontWeight="Bold" Foreground="#202124" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="4" Text="{Binding FormattedMargin}" FontSize="{Binding DataContext.TableContentFontSize, ElementName=rootGrid}" FontWeight="Bold" Foreground="#0F9D58" VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="{Binding MarginVisibility}" />
                                        <TextBlock Grid.Column="5" Text="{Binding FormattedMarginPercentage}" FontSize="{Binding DataContext.TableContentFontSize, ElementName=rootGrid}" Foreground="#80868B" VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="{Binding MarginVisibility}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
            </Border>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
